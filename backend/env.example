# Email Configuration for Login Notifications
# Copy this file to .env and replace with your actual credentials
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Google Gemini API Key
GOOGLE_API_KEY=AIzaSyAtKhIeqFIWlLjPakicIRy3vpH9bbZrEu8

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# OpenAI API Key (if needed)
OPENAI_API_KEY=your-openai-key

# Instructions:
# 1. Copy this file to .env
# 2. Replace SMTP_USER with your Gmail address
# 3. Replace SMTP_PASS with your Gmail App Password (not regular password)
# 4. To get Gmail App Password:
#    - Enable 2-Factor Authentication on Gmail
#    - Go to Google Account → Security → App passwords
#    - Generate new app password for "Mail"
#    - Use that 16-character password here
